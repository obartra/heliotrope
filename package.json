{
  "name": "heliotrope",
  "private": true,
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "pnpm --filter @heliotrope/web dev",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint . --ext .ts,.tsx",
    "typecheck": "tsc -b",
    "build": "pnpm -r run build",
    "emulators": "firebase emulators:start",
    "storybook": "pnpm --filter @heliotrope/web storybook",
    "storybook:build": "pnpm --filter @heliotrope/web build-storybook",
    "cypress": "cypress run",
    "cypress:open": "cypress open",
    "prepare": "husky"
  },
  "devDependencies": {
    "@firebase/rules-unit-testing": "^5.0.0",
    "@types/node": "^20.17.0",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "@vitest/coverage-v8": "^2.1.0",
    "cypress": "^13.15.0",
    "eslint": "^8.57.0",
    "eslint-plugin-heliotrope": "workspace:*",
    "eslint-plugin-import": "^2.31.0",
    "firebase": "^11.0.0",
    "firebase-tools": "^13.29.0",
    "husky": "^9.1.0",
    "lint-staged": "^15.2.0",
    "prettier": "^3.4.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write",
      "vitest related --run"
    ],
    "*.{json,md,css,yml,yaml}": [
      "prettier --write"
    ]
  }
}
